---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Get a Free Demo — Dynamics 365 Customer Insights"
			description="Book a personalized demo of Dynamics 365 Customer Insights with a Microsoft solution expert."
		/>
	</head>
	<body>
		<Header />
		<main>

			<section class="demo-hero">
				<div class="container">
					<div class="demo-layout">

						<!-- Left: value props -->
						<div class="demo-info">
							<span class="section-tag">Free Demo</span>
							<h1>See Customer Insights live in 30 minutes</h1>
							<p>Book a personalized walkthrough with a Dynamics 365 expert. We'll show you exactly how Customer Insights works with your data landscape.</p>

							<ul class="demo-benefits">
								<li>
									<span class="benefit-icon">
										<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
									</span>
									<span>Live demo tailored to your industry</span>
								</li>
								<li>
									<span class="benefit-icon">
										<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
									</span>
									<span>See unified profiles &amp; AI predictions in action</span>
								</li>
								<li>
									<span class="benefit-icon">
										<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
									</span>
									<span>Q&amp;A with a certified solution expert</span>
								</li>
								<li>
									<span class="benefit-icon">
										<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
									</span>
									<span>No commitment — completely free</span>
								</li>
							</ul>

							<div class="social-proof">
								<div class="proof-avatars">
									<div class="proof-avatar" style="background:linear-gradient(135deg,#0078D4,#7B61FF)">MK</div>
									<div class="proof-avatar" style="background:linear-gradient(135deg,#00B7C3,#00AD56)">JP</div>
									<div class="proof-avatar" style="background:linear-gradient(135deg,#FF8C00,#D83B01)">AL</div>
								</div>
								<p>Join <strong>10,000+</strong> companies already using Customer Insights</p>
							</div>
						</div>

						<!-- Right: embedded form -->
						<div class="demo-form-wrapper">
							<div class="form-card">
								<div class="form-card-header">
									<svg width="22" height="22" viewBox="0 0 32 32" fill="none" aria-hidden="true">
										<rect width="32" height="32" rx="8" fill="#0078D4"/>
										<circle cx="16" cy="12" r="4" fill="white"/>
										<path d="M8 26c0-4.418 3.582-8 8-8s8 3.582 8 8" stroke="white" stroke-width="2" stroke-linecap="round"/>
									</svg>
									<span>Request your demo</span>
								</div>
								<div class="form-container">
									<div
										data-form-id='8f8c6498-1f4a-f111-bec5-000d3a3bc43a'
										data-form-api-url='https://public-usa.mkt.dynamics.com/api/v1.0/orgs/77112c4b-6845-f111-b31f-000d3a5c991b/landingpageforms'
										data-cached-form-url='https://assets-usa.mkt.dynamics.com/77112c4b-6845-f111-b31f-000d3a5c991b/digitalassets/forms/8f8c6498-1f4a-f111-bec5-000d3a3bc43a'>
									</div>
									<script is:inline src='https://formui-usa1.mkt.dynamics.com/usa/FormLoader/FormLoader.bundle.js'></script>
								</div>
							</div>
						</div>

					</div>
				</div>
			</section>

			<!-- Trust strip -->
			<section class="trust-strip">
				<div class="container">
					<div class="trust-items">
						<div class="trust-item">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
							<span>Enterprise-grade security</span>
						</div>
						<div class="trust-item">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
							<span>GDPR &amp; CCPA compliant</span>
						</div>
						<div class="trust-item">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
							<span>30-minute demo slot</span>
						</div>
						<div class="trust-item">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.79-1.84a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 15.18v1.74z"/></svg>
							<span>No sales pressure</span>
						</div>
					</div>
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>

<style>
.demo-hero {
	background: var(--surface-light);
	padding: 5rem 0 4rem;
	min-height: 80vh;
}
.demo-layout {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 5rem;
	align-items: start;
}

/* Left info */
.demo-info .section-tag { margin-bottom: 1rem; }
.demo-info h1 {
	font-size: 2.4rem;
	margin-bottom: 1rem;
	line-height: 1.15;
}
.demo-info > p {
	color: var(--text-secondary);
	font-size: 1.05rem;
	margin-bottom: 2rem;
}
.demo-benefits {
	list-style: none;
	padding: 0;
	margin: 0 0 2.5rem;
	display: flex;
	flex-direction: column;
	gap: 0.9rem;
}
.demo-benefits li {
	display: flex;
	align-items: center;
	gap: 0.75rem;
	font-size: 0.95rem;
	color: var(--text-primary);
}
.benefit-icon {
	width: 26px;
	height: 26px;
	border-radius: 50%;
	background: var(--ci-blue);
	color: white;
	display: flex;
	align-items: center;
	justify-content: center;
	flex-shrink: 0;
}
.social-proof {
	display: flex;
	align-items: center;
	gap: 1rem;
	padding-top: 2rem;
	border-top: 1px solid var(--border);
}
.proof-avatars {
	display: flex;
}
.proof-avatar {
	width: 36px;
	height: 36px;
	border-radius: 50%;
	border: 2px solid white;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 0.7rem;
	font-weight: 700;
	color: white;
	margin-left: -8px;
}
.proof-avatar:first-child { margin-left: 0; }
.social-proof p {
	font-size: 0.85rem;
	color: var(--text-secondary);
	margin: 0;
}

/* Form card */
.demo-form-wrapper { position: sticky; top: 90px; }
.form-card {
	background: var(--surface-white);
	border: 1px solid var(--border);
	border-radius: 20px;
	box-shadow: var(--shadow-xl);
	overflow: hidden;
}
.form-card-header {
	display: flex;
	align-items: center;
	gap: 0.75rem;
	padding: 1.25rem 1.75rem;
	border-bottom: 1px solid var(--border);
	background: var(--ci-navy);
	color: white;
	font-weight: 700;
	font-size: 0.95rem;
}
.form-container {
	padding: 1rem;
}
.form-container :global(iframe) {
	width: 100% !important;
	min-height: 480px;
	border: none;
	display: block;
}

/* Trust strip */
.trust-strip {
	background: var(--surface-white);
	border-top: 1px solid var(--border);
	padding: 2rem 0;
}
.trust-items {
	display: flex;
	justify-content: center;
	gap: 3rem;
	flex-wrap: wrap;
}
.trust-item {
	display: flex;
	align-items: center;
	gap: 0.5rem;
	color: var(--text-secondary);
	font-size: 0.88rem;
	font-weight: 500;
}
.trust-item svg { color: var(--ci-blue); flex-shrink: 0; }

/* Responsive */
@media (max-width: 900px) {
	.demo-layout { grid-template-columns: 1fr; gap: 3rem; }
	.demo-form-wrapper { position: static; }
}
@media (max-width: 600px) {
	.demo-info h1 { font-size: 1.9rem; }
	.trust-items { gap: 1.5rem; }
}
</style>

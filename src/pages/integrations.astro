---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const categories = [
	{
		name: "CRM & Sales",
		icon: "💼",
		color: "#0078D4",
		integrations: [
			{ name: "Dynamics 365 Sales", native: true },
			{ name: "Salesforce CRM", native: false },
			{ name: "HubSpot CRM", native: false },
			{ name: "Pipedrive", native: false },
			{ name: "Zoho CRM", native: false },
			{ name: "SAP Sales Cloud", native: false },
		]
	},
	{
		name: "Loyalty & POS",
		icon: "🏅",
		color: "#7B61FF",
		integrations: [
			{ name: "Microsoft Cloud for Retail", native: true },
			{ name: "Talon.One", native: false },
			{ name: "Antavo", native: false },
			{ name: "Oracle Retail", native: false },
			{ name: "NCR / Aloha POS", native: false },
			{ name: "Lightspeed POS", native: false },
		]
	},
	{
		name: "E-commerce",
		icon: "🛒",
		color: "#00AD56",
		integrations: [
			{ name: "Shopify", native: false },
			{ name: "Magento / Adobe Commerce", native: false },
			{ name: "WooCommerce", native: false },
			{ name: "BigCommerce", native: false },
			{ name: "Commercetools", native: false },
			{ name: "SAP Commerce", native: false },
		]
	},
	{
		name: "Analytics & BI",
		icon: "📊",
		color: "#00B7C3",
		integrations: [
			{ name: "Microsoft Fabric", native: true },
			{ name: "Power BI", native: true },
			{ name: "Azure Synapse Analytics", native: true },
			{ name: "Google Analytics 4", native: false },
			{ name: "Amplitude", native: false },
			{ name: "Mixpanel", native: false },
		]
	},
	{
		name: "Customer Service",
		icon: "💬",
		color: "#FF8C00",
		integrations: [
			{ name: "Dynamics 365 Customer Service", native: true },
			{ name: "Zendesk", native: false },
			{ name: "ServiceNow", native: false },
			{ name: "Freshdesk", native: false },
			{ name: "Intercom", native: false },
			{ name: "Salesforce Service Cloud", native: false },
		]
	},
	{
		name: "Data & Cloud",
		icon: "☁️",
		color: "#D83B01",
		integrations: [
			{ name: "Azure Data Lake", native: true },
			{ name: "Azure Blob Storage", native: true },
			{ name: "AWS S3", native: false },
			{ name: "Google BigQuery", native: false },
			{ name: "Snowflake", native: false },
			{ name: "Databricks", native: false },
		]
	}
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Integrations — Dynamics 365 Customer Insights"
			description="Connect Customer Insights to 250+ data sources across CRM, marketing, e-commerce, analytics, and more."
		/>
	</head>
	<body>
		<Header />
		<main>

			<!-- Hero -->
			<section class="integrations-hero">
				<div class="container">
					<span class="section-tag">Integrations</span>
					<h1>Connect every piece of your customer puzzle</h1>
					<p>250+ pre-built connectors bring all your customer data into one platform — no custom engineering needed.</p>
					<div class="hero-chips">
						<span class="chip">CRM</span>
						<span class="chip">Marketing</span>
						<span class="chip">E-commerce</span>
						<span class="chip">Analytics</span>
						<span class="chip">Data Warehouses</span>
						<span class="chip">Customer Service</span>
						<span class="chip">+ 200 more</span>
					</div>
				</div>
			</section>

			<!-- Architecture diagram -->
			<section class="arch-section">
				<div class="container">
					<div class="section-header">
						<span class="section-tag">Architecture</span>
						<h2>One platform, every data source</h2>
						<p>Customer Insights sits at the center of your data ecosystem — ingesting, unifying, and activating data across every tool you use.</p>
					</div>
					<div class="arch-diagram">
						<div class="arch-sources">
							<div class="arch-source">CRM</div>
							<div class="arch-source">Email</div>
							<div class="arch-source">Web</div>
							<div class="arch-source">POS</div>
							<div class="arch-source">App</div>
							<div class="arch-source">Support</div>
						</div>
						<div class="arch-arrows in">
							<div class="arch-arrow"></div>
						</div>
						<div class="arch-core">
							<div class="core-icon">
								<svg width="28" height="28" viewBox="0 0 32 32" fill="none"><rect width="32" height="32" rx="8" fill="#0078D4"/><circle cx="16" cy="12" r="4" fill="white"/><path d="M8 26c0-4.418 3.582-8 8-8s8 3.582 8 8" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>
							</div>
							<div class="core-label">Customer Insights</div>
							<div class="core-sublabel">Unify · Predict · Activate</div>
						</div>
						<div class="arch-arrows out">
							<div class="arch-arrow out-arrow"></div>
						</div>
						<div class="arch-destinations">
							<div class="arch-dest">Marketing</div>
							<div class="arch-dest">Sales</div>
							<div class="arch-dest">Service</div>
							<div class="arch-dest">BI / Reports</div>
							<div class="arch-dest">Custom API</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Integration categories -->
			<section class="categories-section">
				<div class="container">
					<div class="section-header">
						<span class="section-tag">Browse Integrations</span>
						<h2>Built-in connectors by category</h2>
					</div>
					<div class="categories-grid">
						{categories.map(cat => (
							<div class="category-card">
								<div class="cat-header">
									<span class="cat-icon">{cat.icon}</span>
									<h3>{cat.name}</h3>
								</div>
								<ul class="int-list">
									{cat.integrations.map(i => (
										<li>
											<span class="int-name">{i.name}</span>
											{i.native && <span class="native-badge">Native</span>}
										</li>
									))}
								</ul>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- Journeys callout -->
			<section class="journeys-callout">
				<div class="container">
					<div class="jc-inner">
						<div class="jc-icon" aria-hidden="true">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="8 12 12 8 16 12"/><line x1="12" y1="16" x2="12" y2="8"/></svg>
						</div>
						<div class="jc-text">
							<h3>Looking for marketing automation &amp; email sending?</h3>
							<p>You don't need a third-party tool. <strong>Customer Insights Journeys</strong> is built right in — trigger-based and segment-based journeys, email, SMS, push, and in-app, all powered by live CI profile data and AI predictions. No exports, no sync lag, no extra licence.</p>
						</div>
						<a href="/journeys" class="btn-primary jc-btn">Explore Journeys →</a>
					</div>
				</div>
			</section>

			<!-- Custom integrations callout -->
			<section class="custom-section">
				<div class="container">
					<div class="custom-inner">
						<div class="custom-text">
							<span class="section-tag">Custom Integrations</span>
							<h2>Don't see your tool? We've got you covered.</h2>
							<p>Customer Insights includes a powerful REST API, Dataverse connector, and Azure Data Factory support — so you can connect virtually any data source, no matter how niche or custom.</p>
							<ul class="custom-options">
								<li><strong>REST API</strong> — Pull or push data from any HTTP endpoint</li>
								<li><strong>Azure Data Factory</strong> — Build custom pipelines with 90+ connectors</li>
								<li><strong>Dataverse</strong> — Native integration with the Microsoft Power Platform</li>
								<li><strong>SFTP / CSV</strong> — Simple file-based ingestion for legacy systems</li>
							</ul>
						</div>
						<div class="custom-cta-box">
							<div class="cta-box-inner">
								<h3>Need a custom connector?</h3>
								<p>Our solution engineers can build and certify custom connectors for your specific data landscape.</p>
								<a href="/get-demo" class="btn-primary" style="display:block;text-align:center">Talk to an engineer</a>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- CTA -->
			<section class="integrations-cta">
				<div class="container">
					<h2>Start connecting your data today</h2>
					<p>See how easy it is to set up your first integration in a live Customer Insights demo.</p>
					<a href="/get-demo" class="btn-primary btn-lg">Get a Free Demo</a>
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>

<style>
.integrations-hero {
	background: linear-gradient(160deg, #0B1A2E 0%, #0F2645 100%);
	padding: 5rem 0 4rem;
	text-align: center;
}
.integrations-hero .section-tag { margin-bottom: 1rem; }
.integrations-hero h1 { color: white; font-size: 2.8rem; margin-bottom: 1rem; }
.integrations-hero p {
	color: rgba(255,255,255,0.65);
	font-size: 1.05rem;
	max-width: 540px;
	margin: 0 auto 2rem;
}
.hero-chips {
	display: flex;
	justify-content: center;
	gap: 0.5rem;
	flex-wrap: wrap;
}
.chip {
	background: rgba(255,255,255,0.08);
	border: 1px solid rgba(255,255,255,0.14);
	color: rgba(255,255,255,0.7);
	padding: 0.3rem 0.9rem;
	border-radius: 100px;
	font-size: 0.82rem;
	font-weight: 500;
}

/* Architecture diagram */
.arch-section {
	padding: 5rem 0;
	background: var(--surface-white);
}
.arch-diagram {
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 1rem;
	margin-top: 3rem;
	flex-wrap: wrap;
}
.arch-sources, .arch-destinations {
	display: flex;
	flex-direction: column;
	gap: 0.5rem;
}
.arch-source, .arch-dest {
	background: var(--surface-light);
	border: 1px solid var(--border);
	border-radius: 10px;
	padding: 0.5rem 1rem;
	font-size: 0.82rem;
	font-weight: 600;
	color: var(--text-secondary);
	text-align: center;
}
.arch-dest { background: var(--ci-blue-light); color: var(--ci-blue); border-color: rgba(0,120,212,0.2); }
.arch-arrows {
	display: flex;
	align-items: center;
	color: var(--ci-blue);
}
.arch-arrow {
	width: 40px;
	height: 2px;
	background: var(--ci-blue);
	position: relative;
}
.arch-arrow::after {
	content: '';
	position: absolute;
	right: 0;
	top: -4px;
	border: 5px solid transparent;
	border-left-color: var(--ci-blue);
}
.arch-core {
	background: var(--ci-navy);
	border-radius: 16px;
	padding: 1.75rem 2.5rem;
	text-align: center;
	box-shadow: var(--shadow-xl);
}
.core-icon { margin-bottom: 0.5rem; }
.core-label { color: white; font-weight: 700; font-size: 1rem; }
.core-sublabel { color: rgba(255,255,255,0.4); font-size: 0.75rem; margin-top: 0.25rem; }

/* Categories */
.categories-section {
	padding: 5rem 0;
	background: var(--surface-light);
}
.categories-grid {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 1.5rem;
}
.category-card {
	background: var(--surface-white);
	border: 1px solid var(--border);
	border-radius: 16px;
	padding: 1.75rem;
}
.cat-header {
	display: flex;
	align-items: center;
	gap: 0.75rem;
	margin-bottom: 1.25rem;
	padding-bottom: 1rem;
	border-bottom: 1px solid var(--border);
}
.cat-icon { font-size: 1.4rem; }
.cat-header h3 { font-size: 1rem; margin: 0; }
.int-list {
	list-style: none;
	padding: 0;
	margin: 0;
	display: flex;
	flex-direction: column;
	gap: 0.5rem;
}
.int-list li {
	display: flex;
	align-items: center;
	justify-content: space-between;
	font-size: 0.88rem;
	color: var(--text-secondary);
}
.native-badge {
	background: rgba(0,120,212,0.1);
	color: var(--ci-blue);
	font-size: 0.68rem;
	font-weight: 700;
	padding: 0.1rem 0.5rem;
	border-radius: 100px;
}

/* Custom section */
.custom-section {
	padding: 5rem 0;
	background: var(--surface-white);
}
.custom-inner {
	display: grid;
	grid-template-columns: 1fr 380px;
	gap: 4rem;
	align-items: start;
}
.custom-text .section-tag { margin-bottom: 0.75rem; }
.custom-text h2 { margin-bottom: 1rem; }
.custom-text > p { color: var(--text-secondary); margin-bottom: 1.5rem; }
.custom-options {
	list-style: none;
	padding: 0;
	margin: 0;
	display: flex;
	flex-direction: column;
	gap: 0.75rem;
}
.custom-options li { font-size: 0.92rem; color: var(--text-secondary); }
.custom-options li strong { color: var(--text-primary); }
.cta-box-inner {
	background: var(--ci-navy);
	border-radius: 16px;
	padding: 2rem;
}
.cta-box-inner h3 { color: white; margin-bottom: 0.5rem; font-size: 1.1rem; }
.cta-box-inner p { color: rgba(255,255,255,0.55); font-size: 0.9rem; margin-bottom: 1.5rem; }

/* Journeys callout */
.journeys-callout {
	background: linear-gradient(135deg, #EFF6FC, #F0F0FF);
	border-top: 1px solid rgba(0,120,212,0.15);
	border-bottom: 1px solid rgba(0,120,212,0.15);
	padding: 2.5rem 0;
}
.jc-inner {
	display: flex;
	align-items: center;
	gap: 1.75rem;
	flex-wrap: wrap;
}
.jc-icon {
	width: 60px;
	height: 60px;
	background: rgba(0,120,212,0.1);
	border-radius: 16px;
	display: flex;
	align-items: center;
	justify-content: center;
	color: var(--ci-blue);
	flex-shrink: 0;
}
.jc-text { flex: 1; min-width: 240px; }
.jc-text h3 { font-size: 1rem; margin-bottom: 0.4rem; }
.jc-text p { font-size: 0.88rem; color: var(--text-secondary); margin: 0; }
.jc-btn { white-space: nowrap; flex-shrink: 0; }

/* CTA */
.integrations-cta {
	padding: 5rem 0;
	background: var(--ci-navy);
	text-align: center;
}
.integrations-cta h2 { color: white; font-size: 2.2rem; margin-bottom: 0.75rem; }
.integrations-cta p {
	color: rgba(255,255,255,0.6);
	max-width: 480px;
	margin: 0 auto 2rem;
}

/* Responsive */
@media (max-width: 960px) {
	.categories-grid { grid-template-columns: repeat(2, 1fr); }
	.custom-inner { grid-template-columns: 1fr; }
	.arch-diagram { flex-direction: column; }
	.arch-arrows { transform: rotate(90deg); }
}
@media (max-width: 600px) {
	.integrations-hero h1 { font-size: 2rem; }
	.categories-grid { grid-template-columns: 1fr; }
}
</style>

---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>

			<!-- ── Hero ── -->
			<section class="hero">
				<div class="hero-bg-dots"></div>
				<div class="container hero-inner">
					<div class="hero-text">
						<span class="badge badge-dark">Microsoft Dynamics 365</span>
						<h1>Know Every Customer.<br/>Grow Every Relationship.</h1>
						<p>Unify customer data from every touchpoint, predict behavior with AI, and deliver hyper-personalized experiences — at scale.</p>
						<div class="hero-ctas">
							<a href="/get-demo" class="btn-primary btn-lg">Get a Free Demo</a>
							<a href="/about" class="btn-ghost">See how it works →</a>
						</div>
						<div class="trust-row">
							<span>SOC 2 Certified</span>
							<span class="sep">·</span>
							<span>GDPR Compliant</span>
							<span class="sep">·</span>
							<span>ISO 27001</span>
						</div>
					</div>

					<div class="hero-visual" aria-hidden="true">
						<div class="dashboard-card">
							<div class="card-topbar">
								<span class="card-title">Customer 360°</span>
								<span class="live-badge">
									<span class="live-dot"></span> Live
								</span>
							</div>
							<div class="customer-row">
								<div class="avatar">SJ</div>
								<div>
									<div class="customer-name">Sarah Johnson</div>
									<div class="customer-sub">Active · Segment: High-Value</div>
								</div>
							</div>
							<div class="metrics-row">
								<div class="metric-box">
									<div class="metric-val">87<span class="metric-unit">/100</span></div>
									<div class="metric-label">Engagement</div>
								</div>
								<div class="metric-box">
									<div class="metric-val">$4.2k</div>
									<div class="metric-label">Pred. LTV</div>
								</div>
								<div class="metric-box">
									<div class="metric-val">92%</div>
									<div class="metric-label">Retention</div>
								</div>
							</div>
							<div class="activity-section">
								<div class="activity-label">Recent Activity</div>
								<div class="activity-item">
									<span class="dot" style="background:var(--ci-cyan)"></span>
									<span>Web visit</span>
									<span class="time">2m ago</span>
								</div>
								<div class="activity-item">
									<span class="dot" style="background:var(--ci-blue)"></span>
									<span>Email opened</span>
									<span class="time">18m ago</span>
								</div>
								<div class="activity-item">
									<span class="dot" style="background:var(--ci-green)"></span>
									<span>Purchase: €89.00</span>
									<span class="time">2h ago</span>
								</div>
							</div>
							<div class="ai-row">
								<span class="ai-chip">
									<svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M12 2l3 7h7l-5.5 4 2 7L12 16l-6.5 4 2-7L2 9h7z" fill="currentColor"/></svg>
									AI Recommendation
								</span>
								<span class="ai-action">Send loyalty offer →</span>
							</div>
						</div>

						<div class="mini-cards">
							<div class="mini-card">
								<div class="mini-card-icon" style="background:rgba(0,183,195,0.12);color:var(--ci-cyan)">
									<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
								</div>
								<div>
									<div class="mini-card-val">128k</div>
									<div class="mini-card-label">Unified Profiles</div>
								</div>
							</div>
							<div class="mini-card">
								<div class="mini-card-icon" style="background:rgba(0,173,86,0.12);color:var(--ci-green)">
									<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
								</div>
								<div>
									<div class="mini-card-val">+34%</div>
									<div class="mini-card-label">Revenue Lift</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- ── Stats ── -->
			<section class="stats-section">
				<div class="container">
					<div class="stats-grid">
						<div class="stat-item">
							<div class="stat-num">360°</div>
							<div class="stat-desc">Unified Customer View</div>
						</div>
						<div class="stat-item">
							<div class="stat-num">40%</div>
							<div class="stat-desc">Higher Retention Rate</div>
						</div>
						<div class="stat-item">
							<div class="stat-num">3×</div>
							<div class="stat-desc">Faster Time to Value</div>
						</div>
						<div class="stat-item">
							<div class="stat-num">99.9%</div>
							<div class="stat-desc">Platform Uptime SLA</div>
						</div>
					</div>
				</div>
			</section>

			<!-- ── Features ── -->
			<section class="features-section">
				<div class="container">
					<div class="section-header">
						<span class="section-tag">The Platform</span>
						<h2>Everything you need to truly understand your customers</h2>
						<p>Customer Insights brings together data, AI, and activation tools — so you can put customers at the heart of every decision.</p>
					</div>
					<div class="features-grid">
						<div class="feature-card">
							<div class="feature-icon" style="background:rgba(0,120,212,0.1);color:var(--ci-blue)">
								<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
							</div>
							<h3>Unified Profiles</h3>
							<p>Merge identity, behavioral, and transactional data from every source into rich, always-current customer profiles.</p>
						</div>
						<div class="feature-card">
							<div class="feature-icon" style="background:rgba(123,97,255,0.1);color:var(--ci-purple)">
								<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
							</div>
							<h3>AI-Powered Predictions</h3>
							<p>Out-of-the-box models for churn, lifetime value, and next best action — no data science team required.</p>
						</div>
						<div class="feature-card">
							<div class="feature-icon" style="background:rgba(0,183,195,0.1);color:var(--ci-cyan)">
								<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
							</div>
							<h3>Built-in Customer Journeys</h3>
							<p>Trigger real-time, omnichannel journeys the moment a signal fires — email, SMS, push, and in-app, all without a separate marketing tool.</p>
							<a href="/journeys" class="feature-link">Explore Journeys →</a>
						</div>
						<div class="feature-card">
							<div class="feature-icon" style="background:rgba(0,173,86,0.1);color:var(--ci-green)">
								<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
							</div>
							<h3>Journey Analytics</h3>
							<p>Visualize, measure, and optimize every step of the customer journey across channels and touchpoints.</p>
						</div>
					</div>
				</div>
			</section>

			<!-- ── How It Works ── -->
			<section class="how-section">
				<div class="container">
					<div class="section-header">
						<span class="section-tag">How It Works</span>
						<h2>From raw data to revenue in three steps</h2>
					</div>
					<div class="steps-row">
						<div class="step">
							<div class="step-number">01</div>
							<h3>Connect Your Data</h3>
							<p>250+ pre-built connectors bring data from CRM, e-commerce, marketing, and support into one unified platform.</p>
						</div>
						<div class="step-arrow">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
						</div>
						<div class="step">
							<div class="step-number">02</div>
							<h3>Unify &amp; Enrich</h3>
							<p>AI resolves duplicate identities and merges records into a single, accurate profile — enriched with predictive scores.</p>
						</div>
						<div class="step-arrow">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
						</div>
						<div class="step">
							<div class="step-number">03</div>
							<h3>Activate with Journeys</h3>
							<p>Trigger real-time omnichannel journeys directly from unified profiles — no export, no third-party tool, no lag.</p>
						</div>
					</div>
				</div>
			</section>

			<!-- ── Journeys teaser ── -->
			<section class="journeys-teaser">
				<div class="container">
					<div class="jt-inner">
						<div class="jt-text">
							<span class="section-tag">Customer Journeys</span>
							<h2>Don't just know your customers.<br/>Act on it — instantly.</h2>
							<p>Customer Insights Journeys is built in, not bolted on. Trigger omnichannel journeys from live profile data the moment a customer signal fires. No exports, no sync lag, no third-party marketing tool required.</p>
							<div class="jt-bullets">
								<div class="jt-bullet">
									<span class="jt-dot" style="background:var(--ci-green)"></span>
									Trigger-based journeys fire in real time from any CI event
								</div>
								<div class="jt-bullet">
									<span class="jt-dot" style="background:var(--ci-blue)"></span>
									Email, SMS, push, in-app — all in one canvas
								</div>
								<div class="jt-bullet">
									<span class="jt-dot" style="background:var(--ci-purple)"></span>
									AI send-time optimization and dynamic personalization built in
								</div>
							</div>
							<a href="/journeys" class="btn-primary" style="margin-top:0.5rem">Explore Journeys →</a>
						</div>
						<div class="jt-visual" aria-hidden="true">
							<div class="jt-card">
								<div class="jt-card-label">Active Journeys</div>
								<div class="jt-journey-row">
									<span class="jt-badge green">● Live</span>
									<span class="jt-name">Welcome &amp; Onboarding</span>
									<span class="jt-stat">1,284 active</span>
								</div>
								<div class="jt-journey-row">
									<span class="jt-badge green">● Live</span>
									<span class="jt-name">Churn Prevention</span>
									<span class="jt-stat">342 active</span>
								</div>
								<div class="jt-journey-row">
									<span class="jt-badge blue">● Scheduled</span>
									<span class="jt-name">VIP Loyalty Campaign</span>
									<span class="jt-stat">12k audience</span>
								</div>
								<div class="jt-journey-row">
									<span class="jt-badge orange">● Draft</span>
									<span class="jt-name">Win-back Series</span>
									<span class="jt-stat">—</span>
								</div>
								<div class="jt-divider"></div>
								<div class="jt-metrics-row">
									<div class="jt-metric"><span>68%</span><small>Avg open rate</small></div>
									<div class="jt-metric"><span>2.4×</span><small>vs baseline</small></div>
									<div class="jt-metric"><span>34%</span><small>Goal conversion</small></div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- ── Final CTA ── -->
			<section class="cta-section">
				<div class="container">
					<div class="cta-box">
						<div class="cta-glow"></div>
						<span class="badge badge-dark">Limited Demo Slots Available</span>
						<h2>Ready to see Customer Insights in action?</h2>
						<p>Join thousands of companies using Dynamics 365 to build deeper customer relationships and drive measurable growth.</p>
						<div class="cta-buttons">
							<a href="/get-demo" class="btn-primary btn-lg">Get Your Free Demo</a>
							<a href="/journeys" class="btn-ghost">Explore Journeys →</a>
						</div>
					</div>
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>

<style>
/* ── Hero ── */
.hero {
	position: relative;
	background: linear-gradient(135deg, #0B1A2E 0%, #0F2645 55%, #0B2240 100%);
	padding: 6rem 0 5rem;
	overflow: hidden;
}
.hero-bg-dots {
	position: absolute;
	inset: 0;
	background-image: radial-gradient(rgba(255,255,255,0.06) 1px, transparent 1px);
	background-size: 32px 32px;
	pointer-events: none;
}
.hero-inner {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 4rem;
	align-items: center;
}
.hero-text { color: white; }
.hero-text .badge { margin-bottom: 1.5rem; }
.hero-text h1 {
	font-size: 3.4rem;
	line-height: 1.1;
	color: white;
	margin-bottom: 1.25rem;
}
.hero-text p {
	font-size: 1.15rem;
	color: rgba(255,255,255,0.7);
	max-width: 480px;
	margin-bottom: 2rem;
}
.hero-ctas {
	display: flex;
	gap: 1rem;
	flex-wrap: wrap;
	margin-bottom: 2rem;
}
.trust-row {
	display: flex;
	align-items: center;
	gap: 0.6rem;
	font-size: 0.8rem;
	color: rgba(255,255,255,0.4);
}
.sep { color: rgba(255,255,255,0.2); }

/* Dashboard card */
.hero-visual {
	display: flex;
	flex-direction: column;
	gap: 1rem;
}
.dashboard-card {
	background: rgba(255,255,255,0.06);
	backdrop-filter: blur(16px);
	border: 1px solid rgba(255,255,255,0.12);
	border-radius: 16px;
	padding: 1.5rem;
	box-shadow: 0 24px 64px rgba(0,0,0,0.4);
}
.card-topbar {
	display: flex;
	justify-content: space-between;
	align-items: center;
	margin-bottom: 1.25rem;
}
.card-title {
	font-weight: 700;
	font-size: 0.95rem;
	color: white;
}
.live-badge {
	display: flex;
	align-items: center;
	gap: 0.4rem;
	font-size: 0.75rem;
	color: var(--ci-green);
	font-weight: 600;
}
.live-dot {
	width: 7px;
	height: 7px;
	background: var(--ci-green);
	border-radius: 50%;
	animation: pulse 2s infinite;
}
@keyframes pulse {
	0%, 100% { opacity: 1; }
	50% { opacity: 0.4; }
}
.customer-row {
	display: flex;
	align-items: center;
	gap: 0.9rem;
	margin-bottom: 1.25rem;
	padding-bottom: 1.25rem;
	border-bottom: 1px solid rgba(255,255,255,0.08);
}
.avatar {
	width: 42px;
	height: 42px;
	background: linear-gradient(135deg, var(--ci-blue), var(--ci-purple));
	border-radius: 50%;
	display: flex;
	align-items: center;
	justify-content: center;
	font-weight: 700;
	font-size: 0.85rem;
	color: white;
	flex-shrink: 0;
}
.customer-name {
	color: white;
	font-weight: 600;
	font-size: 0.95rem;
}
.customer-sub {
	color: rgba(255,255,255,0.45);
	font-size: 0.78rem;
}
.metrics-row {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 0.5rem;
	margin-bottom: 1.25rem;
	padding-bottom: 1.25rem;
	border-bottom: 1px solid rgba(255,255,255,0.08);
}
.metric-box {
	background: rgba(255,255,255,0.05);
	border-radius: 10px;
	padding: 0.65rem 0.75rem;
	text-align: center;
}
.metric-val {
	font-size: 1.25rem;
	font-weight: 700;
	color: white;
	line-height: 1;
}
.metric-unit {
	font-size: 0.75rem;
	color: rgba(255,255,255,0.45);
}
.metric-label {
	font-size: 0.7rem;
	color: rgba(255,255,255,0.4);
	margin-top: 0.3rem;
}
.activity-section { margin-bottom: 1.25rem; }
.activity-label {
	font-size: 0.72rem;
	font-weight: 700;
	letter-spacing: 0.06em;
	text-transform: uppercase;
	color: rgba(255,255,255,0.3);
	margin-bottom: 0.6rem;
}
.activity-item {
	display: flex;
	align-items: center;
	gap: 0.6rem;
	font-size: 0.82rem;
	color: rgba(255,255,255,0.7);
	padding: 0.3rem 0;
}
.activity-item .time {
	margin-left: auto;
	color: rgba(255,255,255,0.3);
	font-size: 0.75rem;
}
.dot {
	width: 8px;
	height: 8px;
	border-radius: 50%;
	flex-shrink: 0;
}
.ai-row {
	display: flex;
	align-items: center;
	justify-content: space-between;
	background: rgba(0,120,212,0.15);
	border: 1px solid rgba(0,120,212,0.3);
	border-radius: 10px;
	padding: 0.6rem 0.9rem;
}
.ai-chip {
	display: flex;
	align-items: center;
	gap: 0.4rem;
	font-size: 0.75rem;
	font-weight: 600;
	color: rgba(255,255,255,0.5);
}
.ai-action {
	font-size: 0.8rem;
	font-weight: 700;
	color: var(--ci-cyan);
	cursor: pointer;
}

/* Mini cards */
.mini-cards {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 0.75rem;
}
.mini-card {
	background: rgba(255,255,255,0.05);
	border: 1px solid rgba(255,255,255,0.1);
	border-radius: 12px;
	padding: 1rem;
	display: flex;
	align-items: center;
	gap: 0.75rem;
}
.mini-card-icon {
	width: 38px;
	height: 38px;
	border-radius: 10px;
	display: flex;
	align-items: center;
	justify-content: center;
	flex-shrink: 0;
}
.mini-card-val {
	font-size: 1.3rem;
	font-weight: 700;
	color: white;
	line-height: 1;
}
.mini-card-label {
	font-size: 0.72rem;
	color: rgba(255,255,255,0.4);
	margin-top: 0.2rem;
}

/* ── Stats ── */
.stats-section {
	background: var(--ci-navy);
	padding: 3rem 0;
}
.stats-grid {
	display: grid;
	grid-template-columns: repeat(4, 1fr);
	gap: 0;
	text-align: center;
}
.stat-item {
	padding: 1.5rem;
	border-right: 1px solid rgba(255,255,255,0.06);
}
.stat-item:last-child { border-right: none; }
.stat-num {
	font-size: 2.6rem;
	font-weight: 700;
	color: var(--ci-cyan);
	line-height: 1;
	margin-bottom: 0.4rem;
}
.stat-desc {
	font-size: 0.85rem;
	color: rgba(255,255,255,0.45);
}

/* ── Features ── */
.features-section {
	padding: 6rem 0;
	background: var(--surface-light);
}
.section-header {
	text-align: center;
	max-width: 600px;
	margin: 0 auto 3.5rem;
}
.section-header h2 { margin-bottom: 0.75rem; }
.section-header p {
	color: var(--text-secondary);
	font-size: 1.05rem;
	margin: 0;
}
.features-grid {
	display: grid;
	grid-template-columns: repeat(2, 1fr);
	gap: 1.5rem;
}
.feature-card {
	background: var(--surface-white);
	border: 1px solid var(--border);
	border-radius: 16px;
	padding: 2rem;
	transition: box-shadow 0.2s, transform 0.2s;
}
.feature-card:hover {
	box-shadow: var(--shadow-lg);
	transform: translateY(-2px);
}
.feature-icon {
	width: 52px;
	height: 52px;
	border-radius: 14px;
	display: flex;
	align-items: center;
	justify-content: center;
	margin-bottom: 1.25rem;
}
.feature-card h3 { margin-bottom: 0.5rem; }
.feature-card p { color: var(--text-secondary); font-size: 0.95rem; margin: 0 0 0.75rem; }
.feature-link { font-size: 0.88rem; font-weight: 600; color: var(--ci-blue); text-decoration: none; }
.feature-link:hover { text-decoration: underline; }

/* ── How it works ── */
.how-section {
	padding: 6rem 0;
	background: var(--surface-white);
}
.steps-row {
	display: grid;
	grid-template-columns: 1fr auto 1fr auto 1fr;
	gap: 1.5rem;
	align-items: start;
	margin-top: 3rem;
}
.step {
	background: var(--surface-light);
	border-radius: 16px;
	padding: 2rem;
}
.step-number {
	font-size: 2rem;
	font-weight: 700;
	color: var(--ci-blue);
	opacity: 0.3;
	line-height: 1;
	margin-bottom: 0.75rem;
}
.step h3 { margin-bottom: 0.5rem; font-size: 1.1rem; }
.step p { color: var(--text-secondary); font-size: 0.9rem; margin: 0; }
.step-arrow {
	color: var(--text-muted);
	margin-top: 2rem;
	flex-shrink: 0;
}

/* ── Journeys teaser ── */
.journeys-teaser {
	padding: 6rem 0;
	background: var(--surface-light);
}
.jt-inner {
	display: grid;

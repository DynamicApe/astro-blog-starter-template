---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const plans = [
	{
		name: "Essentials",
		price: "€1,500",
		period: "/month",
		description: "For growing teams ready to unify their customer data for the first time.",
		highlight: false,
		cta: "Start free trial",
		ctaHref: "/get-demo",
		features: [
			"Up to 100,000 unified profiles",
			"10 data source connectors",
			"Pre-built AI models (churn, LTV)",
			"Real-time segment builder",
			"Dynamics 365 integration",
			"Standard support (email)",
		]
	},
	{
		name: "Professional",
		price: "€4,200",
		period: "/month",
		description: "For enterprises that need advanced AI, real-time activation, and full compliance.",
		highlight: true,
		badge: "Most Popular",
		cta: "Get a demo",
		ctaHref: "/get-demo",
		features: [
			"Up to 5 million unified profiles",
			"Unlimited data connectors",
			"Advanced AI + custom Azure ML models",
			"Real-time journey triggers",
			"Full compliance suite (GDPR, HIPAA)",
			"Priority support + CSM",
			"API access + webhooks",
			"Custom dashboards & exports",
		]
	},
	{
		name: "Enterprise",
		price: "Custom",
		period: "",
		description: "Tailored for global organizations with complex data environments and dedicated support.",
		highlight: false,
		cta: "Talk to sales",
		ctaHref: "/get-demo",
		features: [
			"Unlimited profiles",
			"Dedicated Azure infrastructure",
			"Private Link & custom data residency",
			"SLA-backed 99.99% uptime",
			"Dedicated solution architect",
			"24/7 enterprise support",
			"Custom integrations & ETL",
			"Executive business reviews",
		]
	}
];

const faqs = [
	{
		q: "How is the profile count calculated?",
		a: "A profile is any individual customer or contact that has been unified in Customer Insights. Duplicate records that are merged together count as a single profile."
	},
	{
		q: "Can I start with a free trial?",
		a: "Yes — the Essentials plan includes a 30-day free trial with no credit card required. You can import up to 10,000 profiles during the trial period."
	},
	{
		q: "Is my data safe on Microsoft Azure?",
		a: "Customer Insights runs on Azure, which is certified for SOC 1/2, ISO 27001, GDPR, HIPAA, and more. Your data is encrypted at rest and in transit, and never used to train Microsoft's AI models."
	},
	{
		q: "Can I upgrade or downgrade my plan?",
		a: "Yes, you can change plans at any time. Upgrades take effect immediately; downgrades apply at the next billing cycle."
	},
	{
		q: "Do you offer non-profit or educational pricing?",
		a: "Yes. Microsoft offers special pricing for qualifying non-profits through the Microsoft for Nonprofits programme. Contact our sales team for details."
	}
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Pricing — Dynamics 365 Customer Insights"
			description="Simple, transparent pricing for Dynamics 365 Customer Insights. Start with a free trial or talk to sales for enterprise options."
		/>
	</head>
	<body>
		<Header />
		<main>

			<!-- Hero -->
			<section class="pricing-hero">
				<div class="container">
					<span class="section-tag">Pricing</span>
					<h1>Transparent pricing that scales with you</h1>
					<p>Start free, upgrade when you're ready. No hidden fees, no surprise overages.</p>
					<div class="toggle-row">
						<span class="toggle-label active" id="monthlyLabel">Monthly</span>
						<div class="toggle-switch" id="billingToggle" role="switch" aria-checked="false" tabindex="0">
							<div class="toggle-thumb"></div>
						</div>
						<span class="toggle-label" id="annualLabel">Annual <span class="save-badge">Save 20%</span></span>
					</div>
				</div>
			</section>

			<!-- Plans -->
			<section class="plans-section">
				<div class="container">
					<div class="plans-grid">
						{plans.map(plan => (
							<div class={`plan-card ${plan.highlight ? 'plan-highlight' : ''}`}>
								{plan.badge && <div class="plan-badge">{plan.badge}</div>}
								<div class="plan-name">{plan.name}</div>
								<div class="plan-price">
									<span class="price-val">{plan.price}</span>
									{plan.period && <span class="price-period">{plan.period}</span>}
								</div>
								<p class="plan-desc">{plan.description}</p>
								<a href={plan.ctaHref} class={plan.highlight ? 'btn-primary' : 'btn-outline'} style="display:block;text-align:center;margin-bottom:1.5rem">
									{plan.cta}
								</a>
								<ul class="plan-features">
									{plan.features.map(f => (
										<li>
											<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
											{f}
										</li>
									))}
								</ul>
							</div>
						))}
					</div>
					<p class="pricing-note">All prices exclude applicable taxes. Enterprise agreements available. <a href="/get-demo">Contact sales</a> for volume discounts.</p>
				</div>
			</section>

			<!-- Feature comparison -->
			<section class="compare-section">
				<div class="container">
					<div class="section-header">
						<span class="section-tag">Compare</span>
						<h2>What's included in each plan</h2>
					</div>
					<div class="compare-table-wrap">
						<table class="compare-table">
							<thead>
								<tr>
									<th>Feature</th>
									<th>Essentials</th>
									<th class="col-highlight">Professional</th>
									<th>Enterprise</th>
								</tr>
							</thead>
							<tbody>
								<tr class="section-row"><td colspan="4">Data &amp; Profiles</td></tr>
								<tr><td>Unified profiles</td><td>100k</td><td class="col-highlight">5M</td><td>Unlimited</td></tr>
								<tr><td>Data source connectors</td><td>10</td><td class="col-highlight">Unlimited</td><td>Unlimited</td></tr>
								<tr><td>Real-time data ingestion</td><td>—</td><td class="col-highlight">✓</td><td>✓</td></tr>
								<tr class="section-row"><td colspan="4">AI &amp; Insights</td></tr>
								<tr><td>Pre-built AI models</td><td>✓</td><td class="col-highlight">✓</td><td>✓</td></tr>
								<tr><td>Custom Azure ML models</td><td>—</td><td class="col-highlight">✓</td><td>✓</td></tr>
								<tr><td>Predictive segment scoring</td><td>—</td><td class="col-highlight">✓</td><td>✓</td></tr>
								<tr class="section-row"><td colspan="4">Activation</td></tr>
								<tr><td>Dynamics 365 integration</td><td>✓</td><td class="col-highlight">✓</td><td>✓</td></tr>
								<tr><td>Third-party exports</td><td>5 destinations</td><td class="col-highlight">Unlimited</td><td>Unlimited</td></tr>
								<tr><td>Real-time journey triggers</td><td>—</td><td class="col-highlight">✓</td><td>✓</td></tr>
								<tr><td>API &amp; webhooks</td><td>—</td><td class="col-highlight">✓</td><td>✓</td></tr>
								<tr class="section-row"><td colspan="4">Security &amp; Support</td></tr>
								<tr><td>GDPR / CCPA tools</td><td>✓</td><td class="col-highlight">✓</td><td>✓</td></tr>
								<tr><td>HIPAA compliance</td><td>—</td><td class="col-highlight">✓</td><td>✓</td></tr>
								<tr><td>Dedicated CSM</td><td>—</td><td class="col-highlight">✓</td><td>✓</td></tr>
								<tr><td>SLA uptime guarantee</td><td>99.9%</td><td class="col-highlight">99.9%</td><td>99.99%</td></tr>
							</tbody>
						</table>
					</div>
				</div>
			</section>

			<!-- FAQ -->
			<section class="faq-section">
				<div class="container">
					<div class="section-header">
						<span class="section-tag">FAQ</span>
						<h2>Frequently asked questions</h2>
					</div>
					<div class="faq-grid">
						{faqs.map(faq => (
							<div class="faq-item">
								<h3>{faq.q}</h3>
								<p>{faq.a}</p>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- CTA -->
			<section class="pricing-cta">
				<div class="container">
					<h2>Still have questions?</h2>
					<p>Our team is happy to walk you through pricing, answer compliance questions, or build a custom quote for your organization.</p>
					<div class="cta-buttons">
						<a href="/get-demo" class="btn-primary btn-lg">Talk to Sales</a>
						<a href="/blog" class="btn-outline">Read case studies →</a>
					</div>
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>

<style>
.pricing-hero {
	background: linear-gradient(160deg, #0B1A2E 0%, #0F2645 100%);
	padding: 5rem 0 4rem;
	text-align: center;
}
.pricing-hero .section-tag { margin-bottom: 1rem; }
.pricing-hero h1 { color: white; font-size: 2.8rem; margin-bottom: 1rem; }
.pricing-hero p {
	color: rgba(255,255,255,0.65);
	font-size: 1.05rem;
	margin-bottom: 2rem;
}
.toggle-row {
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 0.75rem;
}
.toggle-label {
	font-size: 0.9rem;
	color: rgba(255,255,255,0.4);
	cursor: pointer;
}
.toggle-label.active { color: white; font-weight: 600; }
.save-badge {
	background: var(--ci-green);
	color: white;
	font-size: 0.7rem;
	padding: 0.1rem 0.5rem;
	border-radius: 100px;
	font-weight: 700;
	margin-left: 0.25rem;
}
.toggle-switch {
	width: 44px;
	height: 24px;
	background: rgba(255,255,255,0.15);
	border-radius: 12px;
	cursor: pointer;
	position: relative;
	transition: background 0.2s;
}
.toggle-switch.on { background: var(--ci-blue); }
.toggle-thumb {
	position: absolute;
	top: 3px;
	left: 3px;
	width: 18px;
	height: 18px;
	background: white;
	border-radius: 50%;
	transition: transform 0.2s;
}
.toggle-switch.on .toggle-thumb { transform: translateX(20px); }

.plans-section {
	padding: 5rem 0 3rem;
	background: var(--surface-light);
}
.plans-grid {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 1.5rem;
	align-items: start;
	margin-bottom: 1.5rem;
}
.plan-card {
	background: var(--surface-white);
	border: 1px solid var(--border);
	border-radius: 20px;
	padding: 2rem;
	position: relative;
}
.plan-highlight {
	background: var(--ci-navy);
	border-color: var(--ci-blue);
	box-shadow: 0 0 0 2px var(--ci-blue), var(--shadow-xl);
}
.plan-badge {
	position: absolute;
	top: -12px;
	left: 50%;
	transform: translateX(-50%);
	background: var(--ci-blue);
	color: white;
	font-size: 0.75rem;
	font-weight: 700;
	padding: 0.25rem 0.9rem;
	border-radius: 100px;
	white-space: nowrap;
}
.plan-name {
	font-size: 0.85rem;
	font-weight: 700;
	letter-spacing: 0.06em;
	text-transform: uppercase;
	color: var(--text-muted);
	margin-bottom: 0.75rem;
}
.plan-highlight .plan-name { color: rgba(255,255,255,0.4); }
.plan-price {
	display: flex;
	align-items: baseline;
	gap: 0.25rem;
	margin-bottom: 0.75rem;
}
.price-val {
	font-size: 2.8rem;
	font-weight: 700;
	color: var(--text-primary);
	line-height: 1;
}
.plan-highlight .price-val { color: white; }
.price-period {
	font-size: 0.9rem;
	color: var(--text-muted);
}
.plan-desc {
	font-size: 0.9rem;
	color: var(--text-secondary);
	margin-bottom: 1.5rem;
	min-height: 2.5em;
}
.plan-highlight .plan-desc { color: rgba(255,255,255,0.5); }
.plan-features {
	list-style: none;
	padding: 0;
	margin: 0;
	display: flex;
	flex-direction: column;
	gap: 0.6rem;
	border-top: 1px solid var(--border);
	padding-top: 1.25rem;
}
.plan-highlight .plan-features { border-color: rgba(255,255,255,0.1); }
.plan-features li {
	display: flex;
	align-items: center;
	gap: 0.6rem;
	font-size: 0.88rem;
	color: var(--text-secondary);
}
.plan-highlight .plan-features li { color: rgba(255,255,255,0.65); }
.plan-features li svg { color: var(--ci-green); flex-shrink: 0; }
.pricing-note {
	text-align: center;
	font-size: 0.82rem;
	color: var(--text-muted);
	margin: 0;
}

/* Compare table */
.compare-section {
	padding: 5rem 0;
	background: var(--surface-white);
}
.compare-table-wrap {
	overflow-x: auto;
	margin-top: 2.5rem;
	border-radius: 16px;
	border: 1px solid var(--border);
}
.compare-table {
	width: 100%;
	border-collapse: collapse;
	font-size: 0.9rem;
}
.compare-table th {
	padding: 1rem 1.25rem;
	text-align: left;
	background: var(--surface-muted);
	font-weight: 700;
	font-size: 0.85rem;
	border-bottom: 1px solid var(--border);
}
.compare-table th.col-highlight {
	background: var(--ci-navy);
	color: white;
}
.compare-table td {
	padding: 0.75rem 1.25rem;
	border-bottom: 1px solid var(--border);
	color: var(--text-secondary);
}
.compare-table td.col-highlight {
	background: rgba(0,120,212,0.04);
	font-weight: 600;
	color: var(--text-primary);
}
.compare-table .section-row td {
	background: var(--surface-muted);
	font-weight: 700;
	font-size: 0.78rem;
	letter-spacing: 0.06em;
	text-transform: uppercase;
	color: var(--text-muted);
	padding: 0.6rem 1.25rem;
}

/* FAQ */
.faq-section {
	padding: 5rem 0;
	background: var(--surface-light);
}
.faq-grid {
	display: grid;
	grid-template-columns: repeat(2, 1fr);
	gap: 2rem;
	margin-top: 1rem;
}
.faq-item {
	background: var(--surface-white);
	border: 1px solid var(--border);
	border-radius: 14px;
	padding: 1.75rem;
}
.faq-item h3 { font-size: 1rem; margin-bottom: 0.6rem; }
.faq-item p { font-size: 0.9rem; color: var(--text-secondary); margin: 0; }

/* CTA */
.pricing-cta {
	padding: 5rem 0;
	background: var(--ci-navy);
	text-align: center;
}
.pricing-cta h2 { color: white; font-size: 2.2rem; margin-bottom: 0.75rem; }
.pricing-cta p {
	color: rgba(255,255,255,0.6);
	max-width: 500px;
	margin: 0 auto 2rem;
}
.cta-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

/* Responsive */
@media (max-width: 900px) {
	.plans-grid { grid-template-columns: 1fr; max-width: 480px; margin-inline: auto; }
	.faq-grid { grid-template-columns: 1fr; }
}
@media (max-width: 600px) {
	.pricing-hero h1 { font-size: 2rem; }
}
</style>

<script>
const toggle = document.getElementById('billingToggle');
const monthlyLabel = document.getElementById('monthlyLabel');
const annualLabel = document.getElementById('annualLabel');

toggle?.addEventListener('click', () => {
	const isOn = toggle.classList.toggle('on');
	toggle.setAttribute('aria-checked', String(isOn));
	monthlyLabel?.classList.toggle('active', !isOn);
	annualLabel?.classList.toggle('active', isOn);
});
</script>
